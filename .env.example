# EduMatrix Production Environment Configuration

# Supabase (Auth, Database, Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (Private Video Streaming)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=edumatrix-videos

# Authentication & Communication
# External SMTP is required for reliable production OTP delivery
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-smtp-pass
EMAIL_FROM=EduMatrix <noreply@edumatrix.com>

# App Settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
