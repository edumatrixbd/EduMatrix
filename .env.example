# tensionনাই Production Environment Configuration

# Supabase (Auth, Database, Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback supported by the app, but prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (Private Video Streaming)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=tensionnai-videos
R2_PUBLIC_URL=https://your-public-r2-dev-url/bucket-name

# Secure Video Streaming
VIDEO_TOKEN_SECRET=your-hls-token-signing-secret

# Payment Integration (SSLCommerz)
PAYMENT_STORE_ID=your-store-id
PAYMENT_STORE_PASSWORD=your-store-password
PAYMENT_SECRET_KEY=your-payment-secret-key

# Authentication & Communication
# External SMTP is required for reliable production OTP delivery
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-smtp-pass
EMAIL_FROM=tensionনাই <noreply@tensionnai.net>

# App Settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
